# Environment variables for Personal Finance MVP
# Copy to .env.local and fill in values.

# Auth.js / NextAuth
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# Google OAuth 2.0 Client (Web application)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Optional aliases (Auth.js also accepts these)
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=
